// frontend/src/pages/AdminPanel.jsx

import { useState, useEffect } from 'react'
import { useNavigate } from 'react-router-dom'
import '../styles/AdminPanel.css'

import {
  getAllQuestions,
  addQuestion,
  deleteQuestion
} from '../api/questions'

const BASE_URL = 'http://localhost:5000/api'

function AdminPanel() {
  const navigate = useNavigate()

  const [stats, setStats] = useState(null)
  const [loading, setLoading] = useState(true)
  const [tab, setTab] = useState('overview')
  const [questions, setQuestions] = useState([])

  const [form, setForm] = useState({
    department: 'CS',
    subject: '',
    topic: '',
    question: '',
    options: ['', '', '', ''],
    correctAnswer: 0,
    explanation: ''
  })

  const token =
    localStorage.getItem('token')

  const user = JSON.parse(
    localStorage.getItem('user')
  )

  const headers = {
    'Content-Type':
      'application/json',
    Authorization:
      `Bearer ${token}`
  }

  /* ===============================
     API LOADERS
  =============================== */

  const fetchStats = async () => {
    try {
      const res = await fetch(
        `${BASE_URL}/admin/stats`,
        { headers }
      )

      const data =
        await res.json()

      setStats(data)
    } catch (error) {
      console.error(error)
    }
  }

  const loadQuestions =
    async () => {
      try {
        const data =
          await getAllQuestions()

        setQuestions(data || [])
      } catch (error) {
        console.error(error)
      }
    }

  const loadAll = async () => {
    await Promise.all([
      fetchStats(),
      loadQuestions()
    ])

    setLoading(false)
  }

  /* ===============================
     SAFE EFFECT
  =============================== */

  useEffect(() => {
    if (!token) {
      navigate('/login')
      return
    }

    if (user?.role !== 'admin') {
      navigate('/dashboard')
      return
    }

    const init = async () => {
      await loadAll()
    }

    init()
  }, []) // eslint-disable-line

  /* ===============================
     ACTIONS
  =============================== */

  const logout = () => {
    localStorage.clear()
    navigate('/')
  }

  const updateOption = (
    index,
    value
  ) => {
    const updated = [
      ...form.options
    ]

    updated[index] = value

    setForm({
      ...form,
      options: updated
    })
  }

  const handleAddQuestion =
    async (e) => {
      e.preventDefault()

      await addQuestion(form)

      setForm({
        department: 'CS',
        subject: '',
        topic: '',
        question: '',
        options: ['', '', '', ''],
        correctAnswer: 0,
        explanation: ''
      })

      await loadQuestions()

      setTab('questions')
    }

  const removeQuestion =
    async (id) => {
      await deleteQuestion(id)
      loadQuestions()
    }

  if (loading) {
    return (
      <div className="admin-loading-screen">
        Loading Admin Dashboard...
      </div>
    )
  }

  return (
    <div className="admin-page">

      {/* SIDEBAR */}
      <aside className="admin-sidebar">

        <div className="admin-logo">
          ExamDojo
          <span>Admin</span>
        </div>

        <button
          className={`admin-item ${
            tab ===
            'overview'
              ? 'active'
              : ''
          }`}
          onClick={() =>
            setTab(
              'overview'
            )
          }
        >
          📊 Overview
        </button>

        <button
          className={`admin-item ${
            tab ===
            'students'
              ? 'active'
              : ''
          }`}
          onClick={() =>
            setTab(
              'students'
            )
          }
        >
          🏆 Students
        </button>

        <button
          className={`admin-item ${
            tab === 'users'
              ? 'active'
              : ''
          }`}
          onClick={() =>
            setTab('users')
          }
        >
          👥 Users
        </button>

        <button
          className={`admin-item ${
            tab ===
            'questions'
              ? 'active'
              : ''
          }`}
          onClick={() =>
            setTab(
              'questions'
            )
          }
        >
          ❓ Questions
        </button>

        <button
          className={`admin-item ${
            tab ===
            'addQuestion'
              ? 'active'
              : ''
          }`}
          onClick={() =>
            setTab(
              'addQuestion'
            )
          }
        >
          ➕ Add Question
        </button>

        <button
          className="admin-item"
          onClick={() =>
            navigate(
              '/dashboard'
            )
          }
        >
          🏠 Dashboard
        </button>

        <button
          className="admin-item"
          onClick={logout}
        >
          🚪 Logout
        </button>

        <div className="admin-user-box">

          <div className="admin-avatar">
            {user?.name?.charAt(
              0
            )}
          </div>

          <div>
            <strong>
              {user?.name}
            </strong>

            <p>
              Administrator
            </p>
          </div>

        </div>

      </aside>

      {/* MAIN */}
      <main className="admin-main">

        <div className="admin-topbar">

          <div>
            <h2>
              Premium Admin Dashboard
            </h2>

            <p>
              Manage ExamDojo Platform
            </p>
          </div>

          <div className="admin-pill">
            LIVE
          </div>

        </div>

        {/* STATS */}
        <div className="admin-stats">

          <div className="admin-stat-card">
            <span>👥</span>
            <h3>
              {stats?.totalUsers ||
                0}
            </h3>
            <p>
              Total Users
            </p>
          </div>

          <div className="admin-stat-card">
            <span>🔥</span>
            <h3>
              {stats?.activeUsers ||
                0}
            </h3>
            <p>
              Active Users
            </p>
          </div>

          <div className="admin-stat-card">
            <span>📈</span>
            <h3>
              {stats?.newUsersThisWeek ||
                0}
            </h3>
            <p>
              New This Week
            </p>
          </div>

          <div className="admin-stat-card">
            <span>⭐</span>
            <h3>
              {stats?.totalXpEarned ||
                0}
            </h3>
            <p>
              Total XP
            </p>
          </div>

        </div>

        {/* OVERVIEW */}
        {tab ===
          'overview' && (
          <div className="admin-grid">

            <div className="admin-box">
              <h3>
                Department Distribution
              </h3>

              {stats?.deptStats?.map(
                (
                  d,
                  i
                ) => (
                  <div
                    key={i}
                    className="bar-row"
                  >
                    <span>
                      {d._id}
                    </span>

                    <div className="bar-track">
                      <div
                        className="bar-fill"
                        style={{
                          width: `${d.count *
                            20}%`
                        }}
                      />
                    </div>

                    <b>
                      {
                        d.count
                      }
                    </b>
                  </div>
                )
              )}
            </div>

            <div className="admin-box">
              <h3>
                Recent Users
              </h3>

              {stats?.recentUsers?.map(
                (
                  u
                ) => (
                  <div
                    key={
                      u._id
                    }
                    className="mini-row"
                  >
                    <div>
                      <strong>
                        {
                          u.name
                        }
                      </strong>

                      <p>
                        {
                          u.email
                        }
                      </p>
                    </div>

                    <span>
                      {new Date(
                        u.createdAt
                      ).toLocaleDateString()}
                    </span>
                  </div>
                )
              )}
            </div>

          </div>
        )}

        {/* STUDENTS */}
        {tab ===
          'students' && (
          <div className="admin-box">

            <h3>
              Top Students
            </h3>

            <table>
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>XP</th>
                  <th>Level</th>
                  <th>Streak</th>
                </tr>
              </thead>

              <tbody>
                {stats?.topStudents?.map(
                  (
                    u,
                    i
                  ) => (
                    <tr
                      key={
                        u._id
                      }
                    >
                      <td>
                        {i + 1}
                      </td>
                      <td>
                        {u.name}
                      </td>
                      <td>
                        {u.xp}
                      </td>
                      <td>
                        {u.level}
                      </td>
                      <td>
                        🔥{' '}
                        {
                          u.streak
                        }
                      </td>
                    </tr>
                  )
                )}
              </tbody>
            </table>

          </div>
        )}

        {/* USERS */}
        {tab ===
          'users' && (
          <div className="admin-box">

            <h3>
              All Recent Users
            </h3>

            <table>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Date</th>
                </tr>
              </thead>

              <tbody>
                {stats?.recentUsers?.map(
                  (
                    u
                  ) => (
                    <tr
                      key={
                        u._id
                      }
                    >
                      <td>
                        {u.name}
                      </td>
                      <td>
                        {u.email}
                      </td>
                      <td>
                        {new Date(
                          u.createdAt
                        ).toLocaleDateString()}
                      </td>
                    </tr>
                  )
                )}
              </tbody>
            </table>

          </div>
        )}

        {/* QUESTIONS */}
        {tab ===
          'questions' && (
          <div className="admin-box">

            <h3>
              Question Bank
            </h3>

            <table>
              <thead>
                <tr>
                  <th>Dept</th>
                  <th>Topic</th>
                  <th>Question</th>
                  <th>Delete</th>
                </tr>
              </thead>

              <tbody>
                {questions.map(
                  (
                    q
                  ) => (
                    <tr
                      key={
                        q._id
                      }
                    >
                      <td>
                        {
                          q.department
                        }
                      </td>

                      <td>
                        {
                          q.topic
                        }
                      </td>

                      <td>
                        {
                          q.question
                        }
                      </td>

                      <td>
                        <button
                          onClick={() =>
                            removeQuestion(
                              q._id
                            )
                          }
                        >
                          🗑️
                        </button>
                      </td>
                    </tr>
                  )
                )}
              </tbody>
            </table>

          </div>
        )}

        {/* ADD QUESTION */}
        {tab ===
          'addQuestion' && (
          <div className="admin-box">

            <h3>
              Add New Question
            </h3>

            <form
              className="admin-form"
              onSubmit={
                handleAddQuestion
              }
            >

              <select
                value={
                  form.department
                }
                onChange={(e) =>
                  setForm({
                    ...form,
                    department:
                      e.target
                        .value
                  })
                }
              >
                <option>
                  CS
                </option>
                <option>
                  ECE
                </option>
                <option>
                  ME
                </option>
                <option>
                  CE
                </option>
                <option>
                  EE
                </option>
              </select>

              <input
                placeholder="Subject"
                value={
                  form.subject
                }
                onChange={(e) =>
                  setForm({
                    ...form,
                    subject:
                      e.target
                        .value
                  })
                }
              />

              <input
                placeholder="Topic"
                value={
                  form.topic
                }
                onChange={(e) =>
                  setForm({
                    ...form,
                    topic:
                      e.target
                        .value
                  })
                }
              />

              <textarea
                placeholder="Question"
                value={
                  form.question
                }
                onChange={(e) =>
                  setForm({
                    ...form,
                    question:
                      e.target
                        .value
                  })
                }
              />

              {form.options.map(
                (
                  item,
                  index
                ) => (
                  <input
                    key={index}
                    placeholder={`Option ${index +
                      1}`}
                    value={
                      item
                    }
                    onChange={(e) =>
                      updateOption(
                        index,
                        e.target
                          .value
                      )
                    }
                  />
                )
              )}

              <select
                value={
                  form.correctAnswer
                }
                onChange={(e) =>
                  setForm({
                    ...form,
                    correctAnswer:
                      Number(
                        e.target
                          .value
                      )
                  })
                }
              >
                <option value={0}>
                  Correct Option 1
                </option>
                <option value={1}>
                  Correct Option 2
                </option>
                <option value={2}>
                  Correct Option 3
                </option>
                <option value={3}>
                  Correct Option 4
                </option>
              </select>

              <textarea
                placeholder="Explanation"
                value={
                  form.explanation
                }
                onChange={(e) =>
                  setForm({
                    ...form,
                    explanation:
                      e.target
                        .value
                  })
                }
              />

              <button
                className="admin-pill"
                type="submit"
              >
                Save Question
              </button>

            </form>

          </div>
        )}

      </main>

    </div>
  )
}

export default AdminPanel
