import { useState, useEffect } from 'react'
import {
  useNavigate,
  useParams
} from 'react-router-dom'

import { getRoadmap } from '../api/roadmap'
import '../styles/Roadmap.css'

function Roadmap() {
  const navigate = useNavigate()

  const { subjectId } =
    useParams()

  const [subject, setSubject] =
    useState(null)

  const [roadmap, setRoadmap] =
    useState([])

  const [loading, setLoading] =
    useState(true)

  useEffect(() => {
    const loadData = async () => {
      try {
        const data =
          await getRoadmap(
            subjectId
          )

        setSubject(
          data?.subject || null
        )

        setRoadmap(
          data?.roadmap || []
        )
      } catch (error) {
        console.error(error)
      } finally {
        setLoading(false)
      }
    }

    loadData()
  }, [subjectId])

  if (loading) {
    return (
      <div className="roadmap-page loading-center">
        Loading roadmap...
      </div>
    )
  }

  return (
    <div className="roadmap-page">

      <div className="roadmap-top">

        <button
          className="back-btn"
          onClick={() =>
            navigate(-1)
          }
        >
          ← Back
        </button>

        <h1>
          {subject?.name ||
            'Roadmap'}
        </h1>

        <p>
          Complete topics one by one
        </p>

      </div>

      <div className="roadmap-list">

        {roadmap.map(
          (topic, index) => (
            <div
              key={topic._id}
              className={`roadmap-node ${
                topic.completed
                  ? 'done'
                  : topic.unlocked
                  ? 'open'
                  : 'locked'
              }`}
            >

              <div className="node-left">

                <div className="node-circle">
                  {topic.completed
                    ? '✅'
                    : topic.unlocked
                    ? index + 1
                    : '🔒'}
                </div>

              </div>

              <div className="node-content">

                <h3>
                  {topic.name}
                </h3>

                <p>
                  XP:{' '}
                  {topic.xpEarned || 0}
                  {' • '}
                  ⭐{' '}
                  {topic.starsEarned || 0}
                </p>

                {topic.unlocked && (
                  <button
                    className="play-btn"
                    onClick={() =>
                      navigate(
                        '/quiz',
                        {
                          state: {
                            topic:
                              topic.slug ||
                              topic.name
                          }
                        }
                      )
                    }
                  >
                    Play Quiz →
                  </button>
                )}

              </div>

            </div>
          )
        )}

      </div>

    </div>
  )
}

export default Roadmap
