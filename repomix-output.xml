<file path="frontend/src/pages/Leaderboard.jsx">
import { useState, useEffect } from 'react'
import { Link, useNavigate } from 'react-router-dom'
import { getDashboardData, getLeaderboard } from '../api/auth'
import '../styles/Dashboard.css'
import '../styles/Leaderboard.css'

function Leaderboard() {
  const navigate = useNavigate()

  const [user,        setUser]        = useState(null)
  const [filter,      setFilter]      = useState('weekly')
  const [loading,     setLoading]     = useState(true)
  const [leaderboard, setLeaderboard] = useState([])
  const [lbLoading,   setLbLoading]   = useState(false)

  /* USER */
  useEffect(() => {
    const fetchUser = async () => {
      try {
        const token = localStorage.getItem('token')
        if (!token) { navigate('/login'); return }
        const data = await getDashboardData()
        data?._id ? setUser(data) : navigate('/login')
      } catch (err) {
        console.error(err)
        navigate('/login')
      } finally {
        setLoading(false)
      }
    }
    fetchUser()
  }, [navigate])

  /* LEADERBOARD */
  useEffect(() => {
    const fetchLb = async () => {
      setLbLoading(true)
      try {
        const data = await getLeaderboard(filter)
        setLeaderboard(Array.isArray(data) ? data : [])
      } catch (err) {
        console.error(err)
        setLeaderboard([])
      } finally {
        setLbLoading(false)
      }
    }
    fetchLb()
    const interval = setInterval(fetchLb, 30000)
    return () => clearInterval(interval)
  }, [filter])

  const getUserRank = () => {
    if (!user || leaderboard.length === 0) return '-'
    const idx = leaderboard.findIndex(p => p._id === user._id)
    return idx !== -1 ? idx + 1 : '-'
  }

  const getCurrentXp = () => {
    if (!user) return 0
    if (filter === 'weekly')  return user.weeklyXp  || 0
    if (filter === 'monthly') return user.monthlyXp || 0
    return user.xp || 0
  }

  const getPositionClass = (rank) => {
    if (rank === 1) return 'gold'
    if (rank === 2) return 'silver'
    if (rank === 3) return 'bronze'
    return 'normal'
  }

  const getPositionEmoji = (rank) => {
    if (rank === 1) return '🥇'
    if (rank === 2) return '🥈'
    if (rank === 3) return '🥉'
    return `#${rank}`
  }

  const logoutUser = () => {
    localStorage.removeItem('token')
    localStorage.removeItem('user')
    navigate('/')
  }

  /* Podium order: 2nd, 1st, 3rd */
  const podiumOrder = leaderboard.length >= 3
    ? [leaderboard[1], leaderboard[0], leaderboard[2]]
    : []

  if (loading) {
    return <div className="loading-screen">Loading Leaderboard</div>
  }

  return (
    <div className="leaderboard-page">

      {/* SIDEBAR */}
      <aside className="sidebar">
        <div className="sidebar-logo">Exam<span>Dojo</span></div>

        <div className="sidebar-section">Main</div>
        <Link to="/dashboard"   className="sidebar-item"><span className="sidebar-icon">🗺️</span>Learning Path</Link>
        <Link to="/quiz"        className="sidebar-item"><span className="sidebar-icon">❓</span>Daily Quiz</Link>
        <Link to="/leaderboard" className="sidebar-item active"><span className="sidebar-icon">🏆</span>Leaderboard</Link>
        <Link to="/notes"       className="sidebar-item"><span className="sidebar-icon">📝</span>Study Notes</Link>

        <div className="sidebar-section">Account</div>
        <Link to="/profile" className="sidebar-item"><span className="sidebar-icon">👤</span>My Profile</Link>
        <button className="sidebar-item" onClick={logoutUser}>
          <span className="sidebar-icon">🚪</span>Logout
        </button>

        <div className="sidebar-bottom">
          <div className="user-card">
            <div className="user-avatar">{user?.name?.charAt(0)}</div>
            <div>
              <div className="user-info-name">{user?.name}</div>
              <div className="user-info-exam">{user?.examType} Aspirant</div>
            </div>
          </div>
        </div>
      </aside>

      {/* MAIN */}
      <main className="leaderboard-main">

        {/* TOPBAR */}
        <div className="lb-topbar">
          <div>
            <h2>🏆 Leaderboard</h2>
            <p>
              Top aspirants{' '}
              {filter === 'weekly' ? 'this week' : filter === 'monthly' ? 'this month' : 'of all time'}
            </p>
          </div>
          <div className="lb-filter">
            {[
              { key: 'weekly',  label: 'Weekly'   },
              { key: 'monthly', label: 'Monthly'  },
              { key: 'alltime', label: 'All Time' },
            ].map(f => (
              <button
                key={f.key}
                className={`lb-filter-btn ${filter === f.key ? 'active' : ''}`}
                onClick={() => setFilter(f.key)}
              >
                {f.label}
              </button>
            ))}
          </div>
        </div>

        {/* YOUR RANK CARD */}
        <div className="your-rank-card">
          <div>
            <div className="your-rank-title">Your Current Rank</div>
            <div className="your-rank-num">#{getUserRank()}</div>
          </div>
          <div className="your-rank-stats">
            <div className="your-rank-stat">
              <div className="your-rank-stat-num">{getCurrentXp()}</div>
              <div className="your-rank-stat-label">XP</div>
            </div>
            <div className="your-rank-stat">
              <div className="your-rank-stat-num">{user?.streak || 0}</div>
              <div className="your-rank-stat-label">Streak</div>
            </div>
            <div className="your-rank-stat">
              <div className="your-rank-stat-num">{user?.level || 1}</div>
              <div className="your-rank-stat-label">Level</div>
            </div>
          </div>
        </div>

        {/* PODIUM */}
        {!lbLoading && podiumOrder.length === 3 && (
          <div className="podium">
            {podiumOrder.map(player => (
              <div key={player._id} className="podium-item">
                <div className="podium-avatar">
                  {player.rank === 1 && <span className="podium-crown">👑</span>}
                  {player.initials}
                </div>
                <div className="podium-name">{player.name}</div>
                <div className="podium-xp">{player.xp} XP</div>
                <div className="podium-stand">{getPositionEmoji(player.rank)}</div>
              </div>
            ))}
          </div>
        )}

        {/* FULL TABLE */}
        <div className="lb-table-wrap">
          <div className="lb-table-head">
            <h3>Full Rankings</h3>
            <span>
              {lbLoading ? 'Updating...' : `${leaderboard.length} players`}
              <span style={{
                display: 'inline-block', width: 8, height: 8,
                borderRadius: '50%', background: '#22c55e',
                animation: 'pulse 2s infinite'
              }} />
            </span>
          </div>

          {lbLoading ? (
            <div style={{ textAlign: 'center', padding: '40px', color: 'var(--green)', fontWeight: '700' }}>
              Refreshing...
            </div>
          ) : (
            <div className="lb-list">

              {/* Show user row if rank > 10 */}
              {Number(getUserRank()) > 10 && (
                <div className="lb-item me">
                  <div className="lb-position me">#{getUserRank()}</div>
                  <div className="lb-user-avatar" style={{ background: 'linear-gradient(135deg, var(--green), var(--yellow2))' }}>
                    {user?.name?.charAt(0)}
                  </div>
                  <div className="lb-user-info">
                    <div className="lb-user-name">You — {user?.name}</div>
                    <div className="lb-user-sub">{user?.examType} Aspirant</div>
                  </div>
                  <div className="lb-right">
                    <div className="lb-streak">🔥 {user?.streak}</div>
                    <div className="lb-xp-wrap">
                      <div className="lb-xp-num">{getCurrentXp()}</div>
                      <div className="lb-xp-label">XP</div>
                    </div>
                    <div className="lb-level">{user?.level}</div>
                  </div>
                </div>
              )}

              {leaderboard.map(player => {
                const isMe = user?._id === player._id
                return (
                  <div key={player._id} className={`lb-item ${isMe ? 'me' : ''}`}>
                    <div className={`lb-position ${getPositionClass(player.rank)}`}>
                      {getPositionEmoji(player.rank)}
                    </div>
                    <div className="lb-user-avatar">{player.initials}</div>
                    <div className="lb-user-info">
                      <div className="lb-user-name">{isMe ? `You — ${player.name}` : player.name}</div>
                      <div className="lb-user-sub">{player.examType} Aspirant</div>
                    </div>
                    <div className="lb-right">
                      <div className="lb-streak">🔥 {player.streak}</div>
                      <div className="lb-xp-wrap">
                        <div className="lb-xp-num">{player.xp}</div>
                        <div className="lb-xp-label">XP</div>
                      </div>
                      <div className="lb-level">{player.level}</div>
                    </div>
                  </div>
                )
              })}

            </div>
          )}
        </div>

      </main>
    </div>
  )
}

export default Leaderboard
</file>

