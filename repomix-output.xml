  border-bottom: 1px solid #f1f5f9;
}

th {
  color: #64748b;
  font-size: 13px;
}

td {
  color: #0f172a;
  font-weight: 600;
}

td button {
  border: none;
  background: #fee2e2;
  padding: 8px 12px;
  border-radius: 10px;
  cursor: pointer;
}

/* FORM */
.admin-form {
  display: grid;
  gap: 14px;
}

.admin-form input,
.admin-form select,
.admin-form textarea {
  width: 100%;
  border: 1px solid #dbe4ea;
  border-radius: 14px;
  padding: 14px;
  font-size: 14px;
  outline: none;
  font-family: inherit;
}

.admin-form textarea {
  resize: vertical;
  min-height: 110px;
}

.admin-form input:focus,
.admin-form select:focus,
.admin-form textarea:focus {
  border-color: #22c55e;
  box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.12);
}

/* LOADING */
.admin-loading-screen {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  font-weight: 800;
  color: #22c55e;
  background: #f8fff4;
}

/* RESPONSIVE */
@media (max-width: 1100px) {
  .admin-stats {
    grid-template-columns: repeat(2, 1fr);
  }

  .admin-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 850px) {
  .admin-sidebar {
    display: none;
  }

  .admin-main {
    margin-left: 0;
    padding: 18px;
  }
}

@media (max-width: 600px) {
  .admin-stats {
    grid-template-columns: 1fr;
  }

  .admin-topbar h2 {
    font-size: 24px;
  }

  th,
  td {
    padding: 10px;
    font-size: 13px;
  }
}
</file>

<file path="frontend/src/styles/Auth.css">
/* ===== AUTH PAGE ===== */
.auth-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
  position: relative;
  overflow: hidden;
  background: var(--bg);
}

.auth-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.15;
  pointer-events: none;
  animation: blobFloat 8s ease-in-out infinite;
}

.auth-blob1 {
  width: 400px; height: 400px;
  background: var(--green2);
  top: -100px; left: -100px;
}

.auth-blob2 {
  width: 350px; height: 350px;
  background: var(--yellow2);
  bottom: -100px; right: -100px;
  animation-delay: 3s;
}

/* ===== AUTH CARD ===== */
.auth-card {
  background: white;
  border-radius: 28px;
  padding: 48px 44px;
  width: 100%;
  max-width: 460px;
  position: relative;
  z-index: 1;
  box-shadow: 0 20px 60px rgba(0,0,0,0.08);
  border: 1.5px solid rgba(22,163,74,0.1);
  animation: fadeUp 0.5s ease forwards;
}

.auth-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--green), var(--yellow2));
  border-radius: 28px 28px 0 0;
}

/* ===== AUTH HEADER ===== */
.auth-logo {
  text-align: center;
  margin-bottom: 8px;
}

.auth-logo-text {
  font-family: 'Nunito', sans-serif;
  font-size: 28px;
  font-weight: 900;
  background: linear-gradient(135deg, var(--green), var(--yellow2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.auth-title {
  font-family: 'Nunito', sans-serif;
  font-size: 24px;
  font-weight: 800;
  color: var(--text);
  text-align: center;
  margin-bottom: 6px;
}

.auth-sub {
  font-size: 14px;
  color: var(--muted);
  text-align: center;
  margin-bottom: 32px;
}

/* ===== EXAM TYPE SELECTOR ===== */
.exam-selector {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 24px;
}

.exam-option {
  padding: 14px;
  border-radius: 14px;
  border: 2px solid var(--border);
  text-align: center;
  cursor: pointer;
  transition: all 0.2s;
  background: var(--bg);
}

.exam-option:hover {
  border-color: var(--green);
}

.exam-option.active.upsc {
  border-color: var(--green);
  background: rgba(22,163,74,0.08);
}

.exam-option.active.gate {
  border-color: var(--yellow);
  background: rgba(202,138,4,0.08);
}

.exam-option-icon {
  font-size: 24px;
  margin-bottom: 4px;
  display: block;
}

.exam-option-label {
  font-family: 'Nunito', sans-serif;
  font-size: 13px;
  font-weight: 700;
  color: var(--text);
}

.exam-option-sub {
  font-size: 11px;
  color: var(--muted);
}

/* ===== FORM ===== */
.auth-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.form-label {
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
}

.form-input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.form-icon {
  position: absolute;
  left: 14px;
  font-size: 16px;
  pointer-events: none;
}

.form-input {
  width: 100%;
  padding: 12px 14px 12px 42px;
  border-radius: 12px;
  border: 1.5px solid var(--border);
  font-size: 14px;
  font-family: 'Poppins', sans-serif;
  color: var(--text);
  background: var(--bg);
  transition: border-color 0.2s, box-shadow 0.2s;
  outline: none;
}

.form-input:focus {
  border-color: var(--green);
  box-shadow: 0 0 0 3px rgba(22,163,74,0.1);
  background: white;
}

.form-input::placeholder {
  color: #cbd5e1;
}

.password-toggle {
  position: absolute;
  right: 14px;
  background: none;
  border: none;
  font-size: 16px;
  cursor: pointer;
  padding: 0;
  color: var(--muted);
}

/* ===== SUBMIT BUTTON ===== */
.auth-btn {
  background: linear-gradient(135deg, var(--green), var(--green2));
  color: white;
  padding: 14px;
  border-radius: 12px;
  font-family: 'Nunito', sans-serif;
  font-size: 15px;
  font-weight: 700;
  border: none;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
  box-shadow: 0 4px 15px rgba(22,163,74,0.3);
  margin-top: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.auth-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(22,163,74,0.4);
}

.auth-btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
  transform: none;
}

/* ===== DIVIDER ===== */
.auth-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 4px 0;
  color: var(--muted);
  font-size: 12px;
}

.auth-divider::before,
.auth-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: var(--border);
}

/* ===== SWITCH LINK ===== */
.auth-switch {
  text-align: center;
  font-size: 14px;
  color: var(--muted);
  margin-top: 8px;
}

.auth-switch a {
  color: var(--green);
  font-weight: 600;
  text-decoration: none;
  transition: color 0.2s;
}

.auth-switch a:hover {
  color: var(--green2);
  text-decoration: underline;
}

/* ===== ERROR & SUCCESS ===== */
.auth-error {
  background: rgba(239,68,68,0.08);
  border: 1px solid rgba(239,68,68,0.25);
  color: var(--red);
  padding: 10px 14px;
  border-radius: 10px;
  font-size: 13px;
  text-align: center;
}

.auth-success {
  background: rgba(22,163,74,0.08);
  border: 1px solid rgba(22,163,74,0.25);
  color: var(--green);
  padding: 10px 14px;
  border-radius: 10px;
  font-size: 13px;
  text-align: center;
}

/* ===== LOADING SPINNER ===== */
.spinner {
  width: 18px; height: 18px;
  border: 2px solid rgba(255,255,255,0.4);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
  display: inline-block;
}

/* Step indicator */
.reg-steps {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-bottom: 20px;
}
.reg-step {
  width: 30px; height: 30px;
  border-radius: 50%;
  border: 2px solid #ddd;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; font-weight: 600; color: #aaa;
  transition: all 0.25s;
}
.reg-step.active { border-color: var(--primary, #6c63ff); color: var(--primary, #6c63ff); }
.reg-step-line { width: 48px; height: 2px; background: #e0e0e0; border-radius: 2px; }

/* Department grid */
.dept-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin: 16px 0 20px;
}
.dept-card {
  display: flex; flex-direction: column; align-items: center;
  gap: 5px; padding: 14px 8px;
  border: 2px solid #e8e8e8; border-radius: 12px;
  background: #fff; cursor: pointer;
  transition: all 0.2s;
}
.dept-card:hover { border-color: var(--primary, #6c63ff); transform: translateY(-2px); }
.dept-card.selected {
  border-color: var(--primary, #6c63ff);
  background: #f0eeff;
  box-shadow: 0 0 0 3px rgba(108, 99, 255, 0.15);
}
.dept-icon { font-size: 22px; }
.dept-code { font-weight: 700; font-size: 15px; color: var(--primary, #6c63ff); }
.dept-label { font-size: 10px; color: #888; text-align: center; line-height: 1.3; }

/* Step 2 buttons row */
.reg-step-btns { display: flex; gap: 10px; margin-top: 4px; }
.reg-step-btns .auth-btn { flex: 2; }
.auth-btn-outline {
  flex: 1; padding: 12px;
  border: 2px solid #e0e0e0; border-radius: 10px;
  background: transparent; cursor: pointer;
  font-size: 14px; font-weight: 600; color: #666;
  transition: all 0.2s;
}
.auth-btn-outline:hover { border-color: var(--primary, #6c63ff); color: var(--primary, #6c63ff); }

@keyframes spin {
  to { transform: rotate(360deg); }
}

@media (max-width: 480px) {
  .auth-card { padding: 32px 24px; }
}
</file>

<file path="frontend/src/styles/Dashboard.css">
body {
  margin: 0;
  font-family: Poppins;
  background: #f6fff3;
}

/* APP */
.aaa {
  display: flex;
  min-height: 100vh;
}

/* SIDEBAR */
.sidebar {
  width: 240px;
  background: #0f172a;
  color: white;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.logo {
  font-size: 22px;
  font-weight: 900;
  color: #58cc02;
  margin-bottom: 20px;
}

.sidebar button {
  background: transparent;
  border: none;
  color: #cbd5e1;
  padding: 10px;
  text-align: left;
  cursor: pointer;
  border-radius: 10px;
}

.sidebar button:hover {
  background: #58cc02;
  color: white;
}

/* MAIN */
.main {
  flex: 1;
  padding: 25px;
}

/* HEADER */
.header h1 {
  margin: 0;
}

/* XP */
.xp-bar {
  width: 100%;
  height: 12px;
  background: #e5e7eb;
  border-radius: 999px;
  overflow: hidden;
}

.xp-fill {
  height: 100%;
  background: linear-gradient(90deg,#58cc02,#46a302);
  transition: width .5s ease;
}

/* ROADMAP */
.roadmap {
  margin-top: 30px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.node-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 25px;
}

.node {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
}

.node.locked {
  background: #e5e7eb;
}

.node.active {
  background: white;
  border: 4px solid #58cc02;
  animation: pulse 1.2s infinite;
}

.node.completed {
  background: #58cc02;
  color: white;
}

/* LINE */
.line {
  width: 6px;
  height: 60px;
  background: #e5e7eb;
}

.line.completed {
  background: #58cc02;
}

/* PANELS */
.panel {
  margin-top: 20px;
  background: white;
  padding: 15px;
  border-radius: 15px;
}

/* BADGES */
.badge {
  padding: 8px;
  background: #e5e7eb;
  margin-top: 5px;
  border-radius: 10px;
}

.badge.on {
  background: #58cc02;
  color: white;
}

/* LEVEL UP */
.levelup {
  position: fixed;
  top: 30%;
  left: 50%;
  transform: translateX(-50%);
  background: #58cc02;
  color: white;
  padding: 25px 50px;
  font-size: 28px;
  font-weight: 900;
  border-radius: 20px;
  z-index: 999;
}

/* ANIMATIONS */
@keyframes pulse {
  0% { transform: scale(1); }
  100% { transform: scale(1.1); }
}
</file>

<file path="frontend/src/styles/global.css">
@import 'tailwindcss/base';
@import 'tailwindcss/components';
@import 'tailwindcss/utilities';

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

.animate-shimmer {
  animation: shimmer 2s infinite linear;
}

@keyframes shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-5px); }
  75% { transform: translateX(5px); }
}

.animate-shake {
  animation: shake 0.5s ease-in-out;
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  14% { transform: scale(1.1); }
  28% { transform: scale(1); }
  42% { transform: scale(1.1); }
  70% { transform: scale(1); }
}

.animate-heartbeat {
  animation: heartbeat 1.5s ease-in-out infinite;
}

.font-nunito { font-family: 'Nunito', sans-serif; }
.font-dm-sans { font-family: 'DM Sans', sans-serif; }
