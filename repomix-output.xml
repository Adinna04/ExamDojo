// frontend/src/pages/Quiz.jsx

import { useState, useEffect, useRef } from 'react'
import { useNavigate, useLocation } from 'react-router-dom'
import confetti from 'canvas-confetti'
import { addXp, getMe } from '../api/auth'
import { fetchQuestions } from '../api/questions'
import '../styles/Quiz.css'

const TIMER_SECONDS = 30

function Quiz() {
  const navigate = useNavigate()
  const location = useLocation()

  const [questions, setQuestions] = useState([])
  const [dept, setDept] = useState('CS')
  const [current, setCurrent] = useState(0)
  const [selected, setSelected] = useState(null)
  const [answered, setAnswered] = useState(false)
  const [score, setScore] = useState(0)
  const [timeLeft, setTimeLeft] = useState(TIMER_SECONDS)
  const [finished, setFinished] = useState(false)
  const [xpSaved, setXpSaved] = useState(false)
  const [xpError, setXpError] = useState(false)
  const [combo, setCombo] = useState(0)
  const [showCombo, setShowCombo] = useState(false)

  const xpSavedRef = useRef(false)
  const correctSound = useRef(null)
  const wrongSound = useRef(null)

  const question = questions[current]

  /* ===============================
     SOUNDS
  =============================== */
  useEffect(() => {
    correctSound.current = new Audio(
      'https://actions.google.com/sounds/v1/cartoon/clang_and_wobble.ogg'
    )

    wrongSound.current = new Audio(
      'https://actions.google.com/sounds/v1/cartoon/wood_plank_flicks.ogg'
    )
  }, [])

  /* ===============================
     LOAD QUIZ FROM DB
  =============================== */
  useEffect(() => {
    const loadQuiz = async () => {
      try {
        const token = localStorage.getItem('token')

        if (!token) {
          navigate('/login')
          return
        }

        const user = await getMe(token)
        const department = user?.department || 'CS'

        setDept(department)

        const topic = location.state?.topic

        const data = await fetchQuestions({
          department,
          topic,
          limit: 10
        })

        setQuestions(data || [])
      } catch {
        navigate('/login')
      }
    }

    loadQuiz()
  }, [navigate, location.state])

  /* ===============================
     TIMER
  =============================== */
  useEffect(() => {
    if (!questions.length || answered || finished) return

    const timer = setTimeout(() => {
      setTimeLeft((prev) => {
        if (prev <= 1) {
          setAnswered(true)
          setSelected(null)
          setCombo(0)
          return 0
        }

        return prev - 1
      })
    }, 1000)

    return () => clearTimeout(timer)
  }, [timeLeft, answered, finished, questions.length])

  /* ===============================
     SAVE XP
  =============================== */
  useEffect(() => {
    if (!finished || xpSavedRef.current || !questions.length) return

    xpSavedRef.current = true

    const pct = (score / questions.length) * 100

    const xp =
      pct >= 80
        ? score * 50
        : pct >= 60
        ? score * 30
        : pct >= 40
        ? score * 15
        : score * 5

    const stars =
      pct >= 80 ? 3 : pct >= 60 ? 2 : pct >= 40 ? 1 : 0

    if (pct >= 80) {
      confetti({
        particleCount: 220,
        spread: 90,
        origin: { y: 0.6 }
      })
    }

    const topic = questions[0]?.topic || 'general'

    addXp({ xp, topic, stars })
      .then(() => setXpSaved(true))
      .catch(() => setXpError(true))
  }, [finished, score, questions])

  /* ===============================
     SELECT ANSWER
  =============================== */
  const handleSelect = (index) => {
    if (answered) return

    setSelected(index)
    setAnswered(true)

    const isCorrect =
      index === question.correctAnswer

    if (isCorrect) {
      setScore((prev) => prev + 1)
      setCombo((prev) => prev + 1)
      setShowCombo(true)

      correctSound.current?.play().catch(() => {})

      setTimeout(() => {
        setShowCombo(false)
      }, 1100)
    } else {
      setCombo(0)
      wrongSound.current?.play().catch(() => {})
    }
  }

  /* ===============================
     NEXT
  =============================== */
  const handleNext = () => {
    if (current + 1 >= questions.length) {
      setFinished(true)
      return
    }

    setCurrent((prev) => prev + 1)
    setSelected(null)
    setAnswered(false)
    setTimeLeft(TIMER_SECONDS)
    setShowCombo(false)
  }

  /* ===============================
     RETRY
  =============================== */
  const handleRetry = async () => {
    try {
      xpSavedRef.current = false

      const topic = location.state?.topic

      const data = await fetchQuestions({
        department: dept,
        topic,
        limit: 10
      })

      setQuestions(data || [])
      setCurrent(0)
      setSelected(null)
      setAnswered(false)
      setScore(0)
      setTimeLeft(TIMER_SECONDS)
      setFinished(false)
      setXpSaved(false)
      setXpError(false)
      setCombo(0)
      setShowCombo(false)
    } catch {
      navigate('/dashboard')
    }
  }

  const getOptionClass = (index) => {
    if (!answered) return ''

    if (index === question.correctAnswer)
      return 'correct'

    if (
      index === selected &&
      index !== question.correctAnswer
    )
      return 'wrong'

    return ''
  }

  const getTimerClass = () => {
    if (timeLeft <= 5) return 'danger'
    if (timeLeft <= 10) return 'warning'
    return ''
  }

  if (!questions.length) {
    return (
      <div className="quiz-page loading-center">
        Loading quiz...
      </div>
    )
  }

  const pct = (score / questions.length) * 100

  const xpEarned =
    pct >= 80
      ? score * 50
      : pct >= 60
      ? score * 30
      : pct >= 40
      ? score * 15
      : score * 5

  const circleLen = 327

  /* ===============================
     RESULT SCREEN
  =============================== */
  if (finished) {
    return (
      <div className="quiz-page">
        <div className="result-screen">
          <div className="result-card">

            <span className="result-emoji">
              {pct >= 80
                ? '🏆'
                : pct >= 60
                ? '👍'
                : pct >= 40
                ? '📚'
                : '💪'}
            </span>

            <h2 className="result-title">
              {pct >= 80
                ? 'Excellent Work!'
                : pct >= 60
                ? 'Good Job!'
                : pct >= 40
                ? 'Keep Practicing!'
                : "Don't Give Up!"}
            </h2>

            <p className="result-sub">
              You scored {score} out of {questions.length}
            </p>

            <div className="result-stats">

              <div className="result-stat">
                <div className="result-stat-num">
                  {score}/{questions.length}
                </div>
                <div className="result-stat-label">
                  Correct
                </div>
              </div>

              <div className="result-stat">
                <div className="result-stat-num">
                  {Math.round(pct)}%
                </div>
                <div className="result-stat-label">
                  Accuracy
                </div>
              </div>

              <div className="result-stat">
                <div className="result-stat-num">
                  {xpEarned}
                </div>
                <div className="result-stat-label">
                  XP Earned
                </div>
              </div>

            </div>

            <div className="xp-earned">
              {xpSaved
                ? `✅ +${xpEarned} XP added to your profile!`
                : xpError
                ? '⚠️ XP save failed — try again'
                : '⏳ Saving XP...'}
            </div>

            <div className="result-btns">

              <button
                className="btn-outline"
                onClick={handleRetry}
              >
                Try Again
              </button>

              <button
                className="quiz-next-btn"
                style={{ flex: 1 }}
                onClick={() =>
                  navigate('/dashboard')
                }
              >
                Back to Dashboard
              </button>

            </div>

          </div>
        </div>
      </div>
    )
  }

  /* ===============================
     QUIZ SCREEN
  =============================== */
  return (
    <div className="quiz-page">

      <div className="quiz-topbar">

        <button
          className="quiz-back"
          onClick={() =>
            navigate('/dashboard')
          }
        >
          ← Back
        </button>

        <div className="quiz-title">
          {dept} ·{' '}
          {location.state?.topic ||
            'Daily Quiz'}
        </div>

        <div
          className={`quiz-timer-ring ${getTimerClass()}`}
        >
          <svg
            viewBox="0 0 120 120"
            className="timer-svg"
          >
            <circle
              cx="60"
              cy="60"
              r="52"
              className="timer-track"
            />

            <circle
              cx="60"
              cy="60"
              r="52"
              className="timer-progress"
              style={{
                strokeDasharray: circleLen,
                strokeDashoffset:
                  circleLen -
                  (timeLeft /
                    TIMER_SECONDS) *
                    circleLen
              }}
            />
          </svg>

          <div className="timer-center">
            {timeLeft}
            <span>s</span>
          </div>
        </div>

      </div>

      <div className="quiz-progress">

        <div className="progress-info">
          <span>
            Question {current + 1} of{' '}
            {questions.length}
          </span>

          <span>
            ✅ {score} correct
          </span>
        </div>

        <div className="progress-bar">
          <div
            className="progress-fill"
            style={{
              width: `${
                ((current + 1) /
                  questions.length) *
                100
              }%`
            }}
          />
        </div>

      </div>

      {showCombo && combo >= 2 && (
        <div className="combo-pop">
          {combo >= 5
            ? `👑 ${combo}x COMBO!`
            : `🔥 ${combo}x Combo!`}
        </div>
      )}

      <div className="question-card">

        <div className="question-meta">

          <span className="question-tag">
            {question.topic}
          </span>

          <span className="question-num">
            Q{current + 1}
          </span>

        </div>

        <p className="question-text">
          {question.question}
        </p>

        <div className="options-grid">

          {question.options.map(
            (option, index) => (
              <button
                key={index}
                className={`option-btn ${getOptionClass(
                  index
                )}`}
                onClick={() =>
                  handleSelect(index)
                }
                disabled={answered}
              >
                <span className="option-label">
                  {answered &&
                  index ===
                    question.correctAnswer
                    ? '✓'
                    : answered &&
                      index === selected
                    ? '✗'
                    : String.fromCharCode(
                        65 + index
                      )}
                </span>

                {option}
              </button>
            )
          )}

        </div>

        {answered &&
          question.explanation && (
            <div className="explanation-box">
              <h5>
                Explanation
              </h5>

              <p>
                {question.explanation}
              </p>
            </div>
          )}

        {answered && (
          <button
            className="quiz-next-btn"
            onClick={handleNext}
          >
            {current + 1 >=
            questions.length
              ? '🏆 See Results'
              : 'Next Question →'}
          </button>
        )}

      </div>

    </div>
  )
}

export default Quiz
</file>

