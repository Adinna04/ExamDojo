<file path="frontend/src/styles/Navbar.css">
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 60px;
  background: rgba(249, 254, 240, 0.9);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(22, 163, 74, 0.15);
  transition: box-shadow 0.3s;
}

.navbar.scrolled {
  box-shadow: 0 4px 30px rgba(22, 163, 74, 0.12);
}

.navbar-logo {
  font-family: 'Nunito', sans-serif;
  font-size: 24px;
  font-weight: 800;
  background: linear-gradient(135deg, var(--green), var(--yellow2));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  cursor: pointer;
}

.navbar-links {
  display: flex;
  align-items: center;
  gap: 32px;
  list-style: none;
}

.navbar-links a {
  color: var(--muted);
  font-size: 14px;
  font-weight: 500;
  transition: color 0.2s;
  position: relative;
}

.navbar-links a::after {
  content: '';
  position: absolute;
  bottom: -3px; left: 0;
  width: 0; height: 2px;
  background: var(--green);
  transition: width 0.3s;
  border-radius: 2px;
}

.navbar-links a:hover { color: var(--green); }
.navbar-links a:hover::after { width: 100%; }

.navbar-cta {
  background: linear-gradient(135deg, var(--green), var(--green2)) !important;
  color: white !important;
  padding: 10px 24px !important;
  border-radius: 100px !important;
  font-weight: 600 !important;
  box-shadow: 0 4px 15px rgba(22, 163, 74, 0.35) !important;
  transition: transform 0.2s, box-shadow 0.2s !important;
}

.navbar-cta:hover {
  transform: translateY(-2px) !important;
  box-shadow: 0 8px 25px rgba(22, 163, 74, 0.5) !important;
}

.navbar-cta::after { display: none !important; }

@media (max-width: 768px) {
  .navbar { padding: 14px 20px; }
  .navbar-links { display: none; }
}
</file>

<file path="frontend/src/styles/Notes.css">
/* frontend/src/styles/Notes.css */

.notes-page {
  min-height: 100vh;
  background: #f8fff4;
  padding: 32px;
}

.notes-top {
  max-width: 1180px;
  margin: 0 auto 26px;
  display: flex;
  gap: 18px;
  align-items: center;
  flex-wrap: wrap;
}

.notes-top h1 {
  margin: 0 0 6px;
  font-size: 40px;
  color: #0f172a;
}

.notes-top p {
  margin: 0;
  color: #64748b;
  font-size: 17px;
}

.back-btn {
  border: none;
  background: white;
  padding: 12px 18px;
  border-radius: 999px;
  font-weight: 800;
  cursor: pointer;
  box-shadow: 0 8px 18px rgba(0,0,0,0.06);
}

.notes-filters {
  max-width: 1180px;
  margin: 0 auto 26px;
  display: grid;
  grid-template-columns: 1fr 180px;
  gap: 16px;
}

.notes-filters input,
.notes-filters select {
  border: 1px solid #dbe4ea;
  background: white;
  border-radius: 18px;
  padding: 14px 16px;
  font-size: 15px;
  outline: none;
}

.notes-filters input:focus,
.notes-filters select:focus {
  border-color: #58cc02;
  box-shadow: 0 0 0 4px rgba(88,204,2,0.12);
}

.notes-grid {
