import { useEffect, useState } from 'react'
import { useNavigate } from 'react-router-dom'
import confetti from 'canvas-confetti'
import { getDashboardData } from '../api/auth'
import '../styles/Dashboard.css'

const XP_MAX = 500

function Dashboard() {
  const navigate = useNavigate()

  const [user, setUser] = useState(null)
  const [xpProgress, setXpProgress] = useState(0)
  const [showLevelUp, setShowLevelUp] = useState(false)

  const [roadmap] = useState([
    { id: 1, title: 'Basics', status: 'completed' },
    { id: 2, title: 'Core Concepts', status: 'completed' },
    { id: 3, title: 'Practice Mode', status: 'active' },
    { id: 4, title: 'Mock Test', status: 'locked' },
    { id: 5, title: 'Final Boss', status: 'locked' }
  ])

  const [quests] = useState([
    { id: 1, text: 'Complete 1 Quiz', done: false },
    { id: 2, text: 'Study 10 mins Notes', done: false },
    { id: 3, text: 'Maintain streak', done: false }
  ])

  const [badges] = useState([
    { id: 1, name: 'Starter', unlocked: true },
    { id: 2, name: 'Fast Learner', unlocked: true },
    { id: 3, name: 'Pro Solver', unlocked: false }
  ])

  useEffect(() => {
    const load = async () => {
      const data = await getDashboardData()

      if (!data?._id) {
        navigate('/login')
        return
      }

      setUser(data)

      const xp = data.xp || 0
      setXpProgress((xp % XP_MAX) / XP_MAX * 100)
    }

    load()
  }, [navigate])

  const startQuiz = () => {
    const newValue = xpProgress + 25

    setXpProgress(newValue)

    if (newValue >= 100) {
      triggerLevelUp()
      setXpProgress(0)
    }

    navigate('/quiz')
  }

  const triggerLevelUp = () => {
    setShowLevelUp(true)

    confetti({
      particleCount: 150,
      spread: 100,
      origin: { y: 0.6 }
    })

    setTimeout(() => setShowLevelUp(false), 2000)
  }

  return (
    <div className="aaa">

      {/* LEVEL UP POPUP */}
      {showLevelUp && (
        <div className="levelup">
          🎉 LEVEL UP!
        </div>
      )}

      {/* SIDEBAR */}
      <aside className="sidebar">
        <div className="logo">⚡ ExamDojo</div>

        <button onClick={() => navigate('/dashboard')}>
          🗺 Path
        </button>

        <button onClick={() => navigate('/quiz')}>
          ⚔ Quiz
        </button>

        <button onClick={() => navigate('/notes')}>
          📘 Notes
        </button>

        <button onClick={() => navigate('/leaderboard')}>
          🏆 Rank
        </button>
      </aside>

      {/* MAIN */}
      <main className="main">

        {/* HEADER */}
        <div className="header">
          <h1>Welcome {user?.name} 👋</h1>
          <p>Keep your streak alive 🔥</p>
        </div>

        {/* XP BAR */}
        <div className="xp-container">
          <div className="xp-bar">
            <div
              className="xp-fill"
              style={{ width: xpProgress + '%' }}
            />
          </div>
          <p>{Math.round(xpProgress)}% to next level</p>
        </div>

        {/* ROADMAP */}
        <div className="roadmap">

          {roadmap.map((item, i) => (
            <div key={item.id} className="node-block">

              {i !== 0 && (
                <div className={`line ${roadmap[i - 1].status}`} />
              )}

              <div className={`node ${item.status}`}>
                {item.status === 'locked'
                  ? '🔒'
                  : item.status === 'completed'
                  ? '✔'
                  : '🎯'}
              </div>

              <div className="title">{item.title}</div>

              {item.status === 'active' && (
                <button onClick={startQuiz}>
                  Start 🚀
                </button>
              )}

            </div>
          ))}

        </div>

        {/* QUESTS */}
        <div className="panel">

          <h3>🎯 Daily Quests</h3>

          {quests.map(q => (
            <p key={q.id}>✔ {q.text}</p>
          ))}

        </div>

        {/* BADGES */}
        <div className="panel">

          <h3>🏅 Badges</h3>

          {badges.map(b => (
            <div
              key={b.id}
              className={`badge ${b.unlocked ? 'on' : ''}`}
            >
              {b.name}
            </div>
          ))}

        </div>

      </main>

    </div>
  )
}

export default Dashboard
</file>

