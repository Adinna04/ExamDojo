import { useState, useEffect } from 'react'
import { Link, useNavigate } from 'react-router-dom'
import { getDashboardData } from '../api/auth'
import '../styles/Dashboard.css'
import '../styles/Profile.css'

const badgeIcons = {
  Rookie:       '🌱',
  'Streak Star':'🔥',
  'XP Warrior': '⚔️',
  'Quiz Master':'🧠',
  Legend:       '👑'
}

const getLevelName = (level) => {
  if (level <= 2) return 'Beginner'
  if (level <= 5) return 'Scholar'
  if (level <= 8) return 'Expert'
  return 'Champion'
}

function Profile() {
  const navigate = useNavigate()

  const [user,    setUser]    = useState(null)
  const [loading, setLoading] = useState(true)
  const [editing, setEditing] = useState(false)
  const [xpWidth, setXpWidth] = useState(0)
  const [success, setSuccess] = useState('')
  const [error,   setError]   = useState('')

  const [form, setForm] = useState({ name: '', examType: 'GATE', department: 'CS' })

  const updateXpBar = (data) => {
    const lvl        = data.level || 1
    const xp         = data.xp   || 0
    const prevLvlXp  = (lvl - 1) * 500
    const nextLvlXp  = lvl * 500
    const width      = ((xp - prevLvlXp) / (nextLvlXp - prevLvlXp)) * 100
    setTimeout(() => setXpWidth(Math.min(width, 100)), 250)
  }

  const fetchUser = async () => {
    try {
      const token = localStorage.getItem('token')
      if (!token) { navigate('/login'); return }
      const data = await getDashboardData()
      if (data?._id) {
        setUser(data)
        setForm({ name: data.name, examType: data.examType, department: data.department || 'CS' })
        updateXpBar(data)
      } else {
        navigate('/login')
      }
    } catch (err) {
      console.error(err)
      navigate('/login')
    } finally {
      setLoading(false)
    }
  }

  useEffect(() => { fetchUser() }, []) // eslint-disable-line

  const handleSave = async () => {
    try {
      const token = localStorage.getItem('token')
      const res = await fetch(`http://localhost:5000/api/users/${user._id}`, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${token}`
        },
        body: JSON.stringify(form)
      })
      const data = await res.json()
      if (data?._id) {
        const updated = { ...user, ...form }
        setUser(updated)
        localStorage.setItem('user', JSON.stringify(updated))
        setSuccess('Profile updated successfully! ✅')
        setEditing(false)
        setTimeout(() => setSuccess(''), 3000)
      } else {
        setError('Failed to update profile')
        setTimeout(() => setError(''), 3000)
      }
    } catch (err) {
      console.error(err)
      setError('Something went wrong')
      setTimeout(() => setError(''), 3000)
    }
  }

  const logoutUser = () => {
    localStorage.removeItem('token')
    localStorage.removeItem('user')
    navigate('/')
  }

  if (loading) return <div className="loading-screen">Loading Profile</div>

  const accuracy   = user?.totalAttempted > 0
    ? Math.round((user.totalCorrect / user.totalAttempted) * 100) : 0
  const currentLvl = user?.level || 1
  const nextLvl    = currentLvl + 1
  const xpNeeded   = currentLvl * 500 - (user?.xp || 0)
  const badges     = user?.badges || ['Rookie']

  return (
    <div className="profile-page">

      {/* SIDEBAR */}
      <aside className="sidebar">
        <div className="sidebar-logo">Exam<span>Dojo</span></div>

        <div className="sidebar-section">Main</div>
        <Link to="/dashboard"   className="sidebar-item"><span className="sidebar-icon">🗺️</span>Learning Path</Link>
        <Link to="/quiz"        className="sidebar-item"><span className="sidebar-icon">❓</span>Daily Quiz</Link>
        <Link to="/leaderboard" className="sidebar-item"><span className="sidebar-icon">🏆</span>Leaderboard</Link>
        <Link to="/notes"       className="sidebar-item"><span className="sidebar-icon">📝</span>Study Notes</Link>

        <div className="sidebar-section">Account</div>
        <Link to="/profile" className="sidebar-item active"><span className="sidebar-icon">👤</span>My Profile</Link>
        <button className="sidebar-item" onClick={logoutUser}>
          <span className="sidebar-icon">🚪</span>Logout
        </button>

        <div className="sidebar-bottom">
          <div className="user-card">
            <div className="user-avatar">{user?.name?.charAt(0)}</div>
            <div>
              <div className="user-info-name">{user?.name}</div>
              <div className="user-info-exam">{user?.department} · {user?.examType}</div>
            </div>
          </div>
        </div>
      </aside>

      {/* MAIN */}
      <main className="profile-main">

        {success && <div className="profile-success">{success}</div>}
        {error   && <div className="profile-error">{error}</div>}

        {/* HEADER */}
        <div className="profile-header">
          <div className="profile-avatar-big">{user?.name?.charAt(0)}</div>
          <div className="profile-header-info">
            <div className="profile-header-name">{user?.name}</div>
            <div className="profile-header-email">{user?.email}</div>
            <div className="profile-header-badges">
              <span className="profile-badge">{user?.examType} Aspirant</span>
              <span className="profile-badge">{user?.department}</span>
              <span className="profile-badge">Level {user?.level} — {getLevelName(user?.level)}</span>
              <span className="profile-badge">{user?.role === 'admin' ? '🛠️ Admin' : '🎓 Student'}</span>
            </div>
          </div>
        </div>

        {/* STATS */}
        <div className="profile-stats">
          <div className="profile-stat-card">
            <span className="profile-stat-icon">🔥</span>
            <div className="profile-stat-num">{user?.streak || 0}</div>
            <div className="profile-stat-label">Day Streak</div>
          </div>
          <div className="profile-stat-card">
            <span className="profile-stat-icon">⭐</span>
            <div className="profile-stat-num">{user?.xp || 0}</div>
            <div className="profile-stat-label">Total XP</div>
          </div>
          <div className="profile-stat-card">
            <span className="profile-stat-icon">🏆</span>
            <div className="profile-stat-num">{user?.level || 1}</div>
            <div className="profile-stat-label">Current Level</div>
          </div>
          <div className="profile-stat-card">
            <span className="profile-stat-icon">🎯</span>
            <div className="profile-stat-num">{accuracy}%</div>
            <div className="profile-stat-label">Accuracy</div>
          </div>
        </div>

        {/* GRID */}
        <div className="profile-grid">

          {/* LEFT — Personal Info */}
          <div className="profile-card">
            <h3>Personal Information</h3>

            <div className="info-row">
              <div className="info-label">Full Name</div>
              {editing
                ? <input className="info-input" value={form.name} onChange={e => setForm({ ...form, name: e.target.value })} />
                : <div className="info-value">{user?.name}</div>}
            </div>

            <div className="info-row">
              <div className="info-label">Email</div>
              <div className="info-value">{user?.email}</div>
            </div>

            <div className="info-row">
              <div className="info-label">Exam Track</div>
              {editing
                ? (
                  <select className="info-select" value={form.examType} onChange={e => setForm({ ...form, examType: e.target.value })}>
                    <option value="GATE">GATE</option>
                    <option value="UPSC">UPSC</option>
                  </select>
                )
                : <div className="info-value">{user?.examType}</div>}
            </div>

            <div className="info-row">
              <div className="info-label">Department</div>
              {editing
                ? (
                  <select className="info-select" value={form.department} onChange={e => setForm({ ...form, department: e.target.value })}>
                    {['CS','ECE','ME','CE','EE'].map(d => <option key={d} value={d}>{d}</option>)}
                  </select>
                )
                : <div className="info-value">{user?.department}</div>}
            </div>

            <div className="info-row">
              <div className="info-label">Role</div>
              <div className="info-value" style={{ textTransform: 'capitalize' }}>{user?.role}</div>
            </div>

            <div className="info-row">
              <div className="info-label">Member Since</div>
              <div className="info-value">
                {user?.createdAt
                  ? new Date(user.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })
                  : '—'}
              </div>
            </div>

            {editing ? (
              <>
                <button className="cancel-btn" onClick={() => setEditing(false)}>Cancel</button>
                <button className="edit-btn"   onClick={handleSave}>Save Changes</button>
              </>
            ) : (
              <button className="edit-btn" onClick={() => setEditing(true)}>✏️ Edit Profile</button>
            )}
          </div>

          {/* RIGHT — XP + Badges */}
          <div style={{ display: 'flex', flexDirection: 'column', gap: '16px' }}>

            {/* XP PROGRESS */}
            <div className="profile-card">
              <h3>XP Progress</h3>
              <div className="xp-progress-section">
                <div className="xp-progress-top">
                  <div className="xp-progress-label">Level {currentLvl} — {getLevelName(currentLvl)}</div>
                  <div className="xp-progress-count">{user?.xp} XP</div>
                </div>
                <div className="xp-progress-bar">
                  <div className="xp-progress-fill" style={{ width: xpWidth + '%' }} />
                </div>
                <div className="level-info">
                  <span>Level {currentLvl}</span>
                  <span>Level {nextLvl}</span>
                </div>
              </div>
              <div style={{
                background: 'var(--surface2)', borderRadius: 'var(--r-md)',
                padding: '12px 14px', fontSize: '13px', color: 'var(--muted)', fontWeight: '500'
              }}>
                {xpNeeded > 0
                  ? `${xpNeeded} XP needed to reach Level ${nextLvl} 🚀`
                  : `You reached Level ${currentLvl} 🎉`}
              </div>
            </div>

            {/* ACHIEVEMENTS */}
            <div className="profile-card">
              <h3>Achievement Badges</h3>
              <div className="achievements-grid">
                {badges.map((badge, i) => (
                  <div key={i} className="achievement unlocked">
                    <span className="achievement-icon">{badgeIcons[badge] || '🏆'}</span>
                    <span className="achievement-name">{badge}</span>
                  </div>
                ))}
              </div>
            </div>

          </div>

        </div>
      </main>
    </div>
  )
}

export default Profile
</file>

