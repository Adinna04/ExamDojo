import { useState, useEffect } from 'react'
import { useNavigate } from 'react-router-dom'
import '../styles/Notes.css'

const BASE_URL = 'http://localhost:5000/api'

function Notes() {
  const navigate = useNavigate()

  const [notes, setNotes] =
    useState([])

  const [loading, setLoading] =
    useState(true)

  const [search, setSearch] =
    useState('')

  const [selectedDept, setSelectedDept] =
    useState('All')

  const token =
    localStorage.getItem('token')

  const headers = {
    'Content-Type':
      'application/json',
    Authorization:
      `Bearer ${token}`
  }

  useEffect(() => {
    const loadNotes = async () => {
      try {
        const res = await fetch(
          `${BASE_URL}/public/notes`,
          { headers }
        )

        const data =
          await res.json()

        setNotes(data || [])
      } catch (error) {
        console.error(error)
      } finally {
        setLoading(false)
      }
    }

    loadNotes()
  }, []) // eslint-disable-line

  const filteredNotes =
    notes.filter((item) => {
      const matchSearch =
        item.title
          .toLowerCase()
          .includes(
            search.toLowerCase()
          ) ||
        item.subject
          .toLowerCase()
          .includes(
            search.toLowerCase()
          )

      const matchDept =
        selectedDept ===
          'All' ||
        item.department ===
          selectedDept

      return (
        matchSearch &&
        matchDept
      )
    })

  if (loading) {
    return (
      <div className="notes-page loading-center">
        Loading notes...
      </div>
    )
  }

  return (
    <div className="notes-page">

      {/* TOP */}
      <div className="notes-top">

        <button
          className="back-btn"
          onClick={() =>
            navigate('/dashboard')
          }
        >
          ← Back
        </button>

        <div>
          <h1>
            Smart Notes
          </h1>

          <p>
            Study faster with
            premium notes
          </p>
        </div>

      </div>

      {/* FILTERS */}
      <div className="notes-filters">

        <input
          type="text"
          placeholder="Search notes..."
          value={search}
          onChange={(e) =>
            setSearch(
              e.target.value
            )
          }
        />

        <select
          value={
            selectedDept
          }
          onChange={(e) =>
            setSelectedDept(
              e.target.value
            )
          }
        >
          <option>
            All
          </option>
          <option>
            CS
          </option>
          <option>
            ECE
          </option>
          <option>
            ME
          </option>
          <option>
            CE
          </option>
          <option>
            EE
          </option>
        </select>

      </div>

      {/* GRID */}
      <div className="notes-grid">

        {filteredNotes.length ===
        0 ? (
          <div className="empty-box">
            No notes found
          </div>
        ) : (
          filteredNotes.map(
            (item) => (
              <div
                key={
                  item._id
                }
                className="note-card"
              >

                <div className="note-pill">
                  {
                    item.department
                  }
                </div>

                <h3>
                  {
                    item.title
                  }
                </h3>

                <p className="note-subject">
                  {
                    item.subject
                  }
                </p>

                <p className="note-desc">
                  {item.description ||
                    'High quality study material'}
                </p>

                {item.fileUrl ? (
                  <a
                    href={
                      item.fileUrl
                    }
                    target="_blank"
                    rel="noreferrer"
                    className="open-btn"
                  >
                    Open Note →
                  </a>
                ) : (
                  <button className="open-btn disabled-btn">
                    Coming Soon
                  </button>
                )}

              </div>
            )
          )
        )}

      </div>

    </div>
  )
}

export default Notes
